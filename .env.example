# Environment
ENVIRONMENT=development

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Branding
NEXT_PUBLIC_CLIENT_NAME=Enterprise RAG
NEXT_PUBLIC_PRIMARY_COLOR=#1a56db

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Supabase
SUPABASE_URL=your-supabase-url
SUPABASE_PROJECT_ID=your-supabase-project-id
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Frontend-safe Supabase values
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL_DEV=google/gemini-3.1-flash-lite-preview
OPENROUTER_MODEL_PROD=anthropic/claude-sonnet-4-5

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# Neo4j
ENABLE_NEO4J=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# JWT
JWT_SECRET=your-jwt-secret-key

# LlamaParse (LlamaCloud)
LLAMA_CLOUD_API_KEY=your-llamacloud-api-key

# Langfuse
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
